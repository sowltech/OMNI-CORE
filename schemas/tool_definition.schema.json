{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sowl.tech/schemas/tool_definition.schema.json",
  "title": "ToolDefinition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "purpose",
    "risk_class",
    "scopes",
    "approval_required",
    "logging_required",
    "rollback_possible"
  ],
  "properties": {
    "name": { "type": "string" },
    "purpose": { "type": "string" },
    "risk_class": { "type": "string", "enum": ["R0", "R1", "R2", "R3", "R4"] },
    "scopes": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["read", "write", "workflow", "system", "database", "secrets", "network", "delete"]
      }
    },
    "approval_required": { "type": "boolean" },
    "logging_required": { "type": "boolean" },
    "rollback_possible": { "type": "boolean" },
    "inputs": { "type": "array", "items": { "type": "string" } },
    "outputs": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "string" }
  }
}
